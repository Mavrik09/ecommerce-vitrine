# =============================================================================
# .env.example — Referência de configuração da vitrine
#
# Este projeto é 100% estático: não há servidor Node.js nem variáveis de
# ambiente em runtime. As configurações ficam em js/config.js.
#
# Copie os valores abaixo para js/config.js antes de publicar.
# =============================================================================

# Supabase — encontre em: Supabase > Settings > API
SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...   # anon public key (segura para o frontend)

# API do admin (ecommerce-admin) publicada na Vercel
ADMIN_API_URL=https://SEU_PROJETO.vercel.app

# Informações da loja (opcional)
STORE_NAME=Minha Loja
STORE_LOGO_URL=
